# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored (.env*.local) and must never be committed.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# AI provider selection: "ollama" (default) or "mock" (offline heuristics for development)
EXPO_PUBLIC_LLM_PROVIDER=ollama
# Local Ollama endpoint. Do NOT expose 11434 directly to the internet (see CLAUDE.md section 8).
EXPO_PUBLIC_OLLAMA_URL=http://127.0.0.1:11434
EXPO_PUBLIC_OLLAMA_MODEL=llama3:latest
